# Backend Environment Variables
APP_NAME=JAGGER SWAP
APP_VERSION=1.0.0
DEBUG=false

# API Settings
API_PREFIX=/api/v1

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Camera Settings
DEFAULT_RESOLUTION=1280x720
TARGET_FPS=30

# Animation Settings (for future AI modules)
ANIMATION_MODEL_PATH=
ANIMATION_ENABLED=false
